---
import '../styles/global.css';
const { title } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | 歯科研修医のためのAIリテラシー学習ハブ</title>
  </head>
  <body class="bg-gray-50 text-gray-800 min-h-screen flex flex-col">

    <!-- ヘッダー -->
    <header class="bg-white border-b border-gray-200 px-6 py-4 sticky top-0 z-10 shadow-sm">
      <div class="max-w-5xl mx-auto flex justify-between items-center">
        <a href="/" class="flex items-center gap-2">
          <span class="text-teal-600 font-bold text-lg">🦷 AI学習ハブ</span>
          <span class="hidden md:inline text-xs text-gray-400 border border-gray-200 rounded px-2 py-0.5">歯科研修医向け</span>
        </a>
        <nav class="flex gap-4 text-sm text-gray-600">
          <a href="/" class="hover:text-teal-600 transition">ホーム</a>
          <a href="/step1" class="hover:text-teal-600 transition">STEP1</a>
          <a href="/step2" class="hover:text-teal-600 transition">STEP2</a>
          <a href="/step3" class="hover:text-teal-600 transition">STEP3</a>
          <a href="/step4" class="hover:text-teal-600 transition">STEP4</a>
          <a href="/glossary" class="hover:text-teal-600 transition">用語集</a>
          <a href="/faq" class="hover:text-teal-600 transition">FAQ</a>
        </nav>
      </div>
    </header>

    <!-- メインコンテンツ -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- フッター -->
    <footer class="bg-gray-800 text-gray-400 text-sm py-8 px-6 mt-16">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
        <div>
          <p class="text-white font-bold mb-1">🦷 歯科研修医のためのAIリテラシー学習ハブ</p>
          <p class="text-xs">本サイトは教育目的のコンテンツです。臨床判断は必ず指導医に確認してください。</p>
        </div>
        <div class="text-xs text-gray-500">
          <p>参加者限定コンテンツ（検索エンジン非公開）</p>
          <p class="mt-1">© 2026 AI学習ハブ. All rights reserved.</p>
        </div>
      </div>
    </footer>

  </body>
</html>
